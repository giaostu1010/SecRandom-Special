<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls2="using:SecRandom.Core.Controls">
    <Design.PreviewWith>
        <controls2:FluentIcon />
    </Design.PreviewWith>

    <Style Selector="controls2|FluentIcon">
        <Setter Property="FontFamily" Value="{DynamicResource FluentSystemIconsResizeable}"/>
    </Style>
</Styles>
