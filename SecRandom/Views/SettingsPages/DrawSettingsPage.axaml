<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:langs="using:SecRandom.Langs.Common"
             xmlns:pageLangs="using:SecRandom.Langs.SettingsPages.DrawSettingsPage"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SecRandom.Views.SettingsPages.DrawSettingsPage">
    <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
        <TextBlock Text="{x:Static langs:Resources.DrawSettings}"
                   FontSize="20"
                   FontWeight="SemiBold"/>
        
        <TextBlock Text="{x:Static pageLangs:Resources.DrawSettingsNavHint}"
                   Opacity="0.8"/>
    </StackPanel>
</UserControl>
