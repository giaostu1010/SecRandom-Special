<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:langs="using:SecRandom.Langs.Common"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SecRandom.Views.SettingsPages.SecuritySettingsPage">
    <StackPanel Orientation="Vertical" Margin="12 12 18 12">
        <TextBlock Text="{x:Static langs:Resources.SecuritySettings}" />
    </StackPanel>
</UserControl>
