<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:controls="clr-namespace:SecRandom.Core.Controls;assembly=SecRandom.Core"
             xmlns:pageLangs="using:SecRandom.Langs.SettingsPages.ThemeManagementPage"
             xmlns:configModels="using:SecRandom.Models.Config"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SecRandom.Views.SettingsPages.ThemeManagementPage"
             x:DataType="configModels:ThemeManagementSettingsConfig">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
            <TextBlock Text="{x:Static pageLangs:Resources.ThemeManagement}"
                       FontSize="14"
                       FontWeight="SemiBold"/>

            <TextBlock Text="{x:Static pageLangs:Resources.MainWindowBackground}"
                       FontSize="14"
                       FontWeight="SemiBold"/>

            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundType}"
                                         Description="{x:Static pageLangs:Resources.BackgroundTypeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding MainWindowBackgroundMode}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundDefault}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundColor}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundImage}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundColorSolid}"
                                         Description="{x:Static pageLangs:Resources.BackgroundColorSolidDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ColorPicker Color="{Binding MainWindowBackgroundColor, Mode=TwoWay}" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundImageFile}"
                                         Description="{x:Static pageLangs:Resources.BackgroundImageFileDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8B9;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding MainWindowBackgroundImageFileName}"
                                       VerticalAlignment="Center"
                                       MaxWidth="200"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Content="{x:Static pageLangs:Resources.SelectImage}" 
                                    MinWidth="60"
                                    Click="SelectMainWindowImage_Click"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.ImageBrightness}"
                                         Description="{x:Static pageLangs:Resources.ImageBrightnessDesc}"
                                         IconSource="{controls:FluentIconSource &#xE706;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider Value="{Binding MainWindowBackgroundBrightness}"
                                    Minimum="0"
                                    Maximum="100"
                                    Width="100"/>
                            <TextBlock Text="{Binding MainWindowBackgroundBrightness, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"
                                       MinWidth="40"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>

            <TextBlock Text="{x:Static pageLangs:Resources.SettingsWindowBackground}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,12,0,0"/>

            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundType}"
                                         Description="{x:Static pageLangs:Resources.BackgroundTypeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding SettingsWindowBackgroundMode}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundDefault}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundColor}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundImage}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundColorSolid}"
                                         Description="{x:Static pageLangs:Resources.BackgroundColorSolidDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ColorPicker Color="{Binding SettingsWindowBackgroundColor, Mode=TwoWay}" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundImageFile}"
                                         Description="{x:Static pageLangs:Resources.BackgroundImageFileDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8B9;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding SettingsWindowBackgroundImageFileName}"
                                       VerticalAlignment="Center"
                                       MaxWidth="200"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Content="{x:Static pageLangs:Resources.SelectImage}" 
                                    MinWidth="60"
                                    Click="SelectSettingsWindowImage_Click"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.ImageBrightness}"
                                         Description="{x:Static pageLangs:Resources.ImageBrightnessDesc}"
                                         IconSource="{controls:FluentIconSource &#xE706;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider Value="{Binding SettingsWindowBackgroundBrightness}"
                                    Minimum="0"
                                    Maximum="100"
                                    Width="100"/>
                            <TextBlock Text="{Binding SettingsWindowBackgroundBrightness, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"
                                       MinWidth="40"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>

            <TextBlock Text="{x:Static pageLangs:Resources.NotificationFloatingWindowBackground}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,12,0,0"/>

            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundType}"
                                         Description="{x:Static pageLangs:Resources.BackgroundTypeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding NotificationFloatingWindowBackgroundMode}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundDefault}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundColor}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.BackgroundImage}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundColorSolid}"
                                         Description="{x:Static pageLangs:Resources.BackgroundColorSolidDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ColorPicker Color="{Binding NotificationFloatingWindowBackgroundColor, Mode=TwoWay}" />
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.BackgroundImageFile}"
                                         Description="{x:Static pageLangs:Resources.BackgroundImageFileDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8B9;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding NotificationFloatingWindowBackgroundImageFileName}"
                                       VerticalAlignment="Center"
                                       MaxWidth="200"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button Content="{x:Static pageLangs:Resources.SelectImage}" 
                                    MinWidth="60"
                                    Click="SelectNotificationWindowImage_Click"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.ImageBrightness}"
                                         Description="{x:Static pageLangs:Resources.ImageBrightnessDesc}"
                                         IconSource="{controls:FluentIconSource &#xE706;}">
                    <fa:SettingsExpanderItem.Footer>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider Value="{Binding NotificationFloatingWindowBackgroundBrightness}"
                                    Minimum="0"
                                    Maximum="100"
                                    Width="100"/>
                            <TextBlock Text="{Binding NotificationFloatingWindowBackgroundBrightness, StringFormat={}{0}%}"
                                       VerticalAlignment="Center"
                                       MinWidth="40"/>
                        </StackPanel>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
