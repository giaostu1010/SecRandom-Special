<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SecRandom.Views.SettingsPages.ListManagementSubPages.LotterySubPages.ExportPrizePage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
            <!-- 当前奖池 -->
            <TextBlock x:Name="CurrentPoolTextBlock"
                       Text="当前奖池：未选择"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            
            <!-- 说明 -->
            <TextBlock Text="将当前奖池的奖品名单导出为文件。支持多种格式导出。"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            
            <!-- 导出设置 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="12">
                    <TextBlock Text="导出设置"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    
                    <!-- 导出格式 -->
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0"
                                   Text="导出格式："
                                   VerticalAlignment="Center"
                                   Width="100"/>
                        <ComboBox x:Name="FormatComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="JSON 文件 (.json)"/>
                            <ComboBoxItem Content="CSV 文件 (.csv)"/>
                            <ComboBoxItem Content="TXT 文件 (.txt)"/>
                        </ComboBox>
                    </Grid>
                    
                    <!-- 奖品数量 -->
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Grid.Column="0"
                                   Text="奖品数量："
                                   VerticalAlignment="Center"
                                   Width="100"/>
                        <TextBlock x:Name="PrizeCountTextBlock"
                                   Grid.Column="1"
                                   Text="0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- 预览区域 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="数据预览"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    
                    <DataGrid x:Name="PreviewDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MinHeight="200"
                              MaxHeight="300"
                              x:CompileBindings="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编号" Binding="{Binding Id, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Count, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="权重" Binding="{Binding Weight, Mode=OneWay}" Width="100"/>
                            <DataGridTextColumn Header="标签" Binding="{Binding TagsDisplay, Mode=OneWay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- 按钮区域 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="RefreshButton"
                        Content="刷新"
                        Click="RefreshButton_OnClick"/>
                <Button x:Name="ExportButton"
                        Content="导出"
                        Classes="accent"
                        Click="ExportButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
