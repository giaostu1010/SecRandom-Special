<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:pageLangs="using:SecRandom.Langs.SettingsPages.ListManagementPage"
             xmlns:models="clr-namespace:SecRandom.Core.Models;assembly=SecRandom.Core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SecRandom.Views.SettingsPages.ListManagementSubPages.LotterySubPages.PrizeSettingsPage"
             x:DataType="models:PrizeItem">
    
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- 标题区域 -->
        <StackPanel Grid.Row="0" Margin="12" Spacing="8">
            <TextBlock Text="{x:Static pageLangs:Resources.PrizeSettingsPageTitle}" FontSize="20" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Static pageLangs:Resources.SelectPoolLabel}" VerticalAlignment="Center"/>
                <ComboBox x:Name="PoolNameComboBox" MinWidth="200"
                          SelectionChanged="PoolNameComboBox_OnSelectionChanged"/>
            </StackPanel>
        </StackPanel>
        
        <!-- 数据表格 -->
        <DataGrid Grid.Row="1" x:Name="PrizeDataGrid" Margin="12,0"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  GridLinesVisibility="All"
                  BorderThickness="1"
                  BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static pageLangs:Resources.ColumnId}" Binding="{Binding Id}" IsReadOnly="True" Width="60"/>
                <DataGridTextColumn Header="{x:Static pageLangs:Resources.ColumnName}" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="{x:Static pageLangs:Resources.ColumnWeight}" Binding="{Binding Weight}" Width="80"/>
                <DataGridTextColumn Header="{x:Static pageLangs:Resources.ColumnCount}" Binding="{Binding Count}" Width="80"/>
                <DataGridCheckBoxColumn Header="{x:Static pageLangs:Resources.ColumnEnabled}" Binding="{Binding Exist}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                Padding="12" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="AddPrizeButton" Content="{x:Static pageLangs:Resources.AddPrize}"
                        Click="AddPrizeButton_OnClick"/>
                <Button x:Name="DeletePrizeButton" Content="{x:Static pageLangs:Resources.DeleteSelected}"
                        Click="DeletePrizeButton_OnClick"/>
                <Button x:Name="SaveButton" Content="{x:Static pageLangs:Resources.Save}"
                        Click="SaveButton_OnClick" Margin="16,0,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
