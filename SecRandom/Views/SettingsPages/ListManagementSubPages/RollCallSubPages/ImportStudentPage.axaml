<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SecRandom.Views.SettingsPages.ListManagementSubPages.RollCallSubPages.ImportStudentPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
            <!-- 标题 -->
            <TextBlock Text="导入学生名单"
                       FontSize="20"
                       FontWeight="SemiBold"/>
            
            <!-- 当前班级 -->
            <TextBlock x:Name="CurrentClassTextBlock"
                       Text="当前班级：未选择"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            
            <!-- 文件选择区域 -->
            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="选择文件"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock x:Name="FilePathTextBlock"
                                   Grid.Column="0"
                                   Text="未选择文件"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="SelectFileButton"
                                Grid.Column="1"
                                Content="选择文件"
                                Click="SelectFileButton_OnClick"
                                Margin="8 0 0 0"/>
                    </Grid>
                    
                    <TextBlock Text="支持格式：Excel (.xlsx, .xls)、CSV (.csv)、TXT (.txt)、JSON (.json)"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                </StackPanel>
            </Border>
            
            <!-- 列映射区域 -->
            <Border x:Name="ColumnMappingBorder"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    IsVisible="False">
                <StackPanel Spacing="8">
                    <TextBlock Text="列映射设置"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    
                    <TextBlock Text="请选择文件中对应的列"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    
                    <!-- 学号列 -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0 4 0 0">
                        <TextBlock Grid.Column="0"
                                   Text="学号列："
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <ComboBox x:Name="IdColumnComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 姓名列 -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0 4 0 0">
                        <TextBlock Grid.Column="0"
                                   Text="姓名列："
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <ComboBox x:Name="NameColumnComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 性别列 -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0 4 0 0">
                        <TextBlock Grid.Column="0"
                                   Text="性别列："
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <ComboBox x:Name="GenderColumnComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 小组列 -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0 4 0 0">
                        <TextBlock Grid.Column="0"
                                   Text="小组列："
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <ComboBox x:Name="GroupColumnComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                    
                    <!-- 标签列 -->
                    <Grid ColumnDefinitions="Auto, *" Margin="0 4 0 0">
                        <TextBlock Grid.Column="0"
                                   Text="标签列："
                                   VerticalAlignment="Center"
                                   Width="80"/>
                        <ComboBox x:Name="TagsColumnComboBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- 预览区域 -->
            <Border x:Name="PreviewBorder"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    IsVisible="False">
                <StackPanel Spacing="8">
                    <TextBlock Text="数据预览"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    
                    <DataGrid x:Name="PreviewDataGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MinHeight="150"
                              MaxHeight="200"
                              x:CompileBindings="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="学号" Binding="{Binding Id, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="姓名" Binding="{Binding Name, Mode=OneWay}" Width="*"/>
                            <DataGridTextColumn Header="性别" Binding="{Binding Gender, Mode=OneWay}" Width="80"/>
                            <DataGridTextColumn Header="小组" Binding="{Binding Group, Mode=OneWay}" Width="100"/>
                            <DataGridTextColumn Header="标签" Binding="{Binding TagsDisplay, Mode=OneWay}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            
            <!-- 按钮区域 -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button x:Name="CancelButton"
                        Content="取消"
                        Click="CancelButton_OnClick"/>
                <Button x:Name="ImportButton"
                        Content="导入"
                        Classes="accent"
                        IsEnabled="False"
                        Click="ImportButton_OnClick"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
