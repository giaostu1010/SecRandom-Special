<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:controls="clr-namespace:SecRandom.Core.Controls;assembly=SecRandom.Core"
             xmlns:pageLangs="using:SecRandom.Langs.SettingsPages.HistoryPage"
             mc:Ignorable="d" d:DesignWidth="800"
             x:Class="SecRandom.Views.SettingsPages.HistoryManagementSubPages.TableSubPages.LotteryHistoryTableSubPage">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.SelectPool}"
                                         Description="{x:Static pageLangs:Resources.SelectPoolDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8F1;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="PoolNameComboBox"
                                  MinWidth="160"
                                  SelectedIndex="0"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.ViewMode}"
                                         Description="{x:Static pageLangs:Resources.Settings_ViewModeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8A1;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="ViewModeComboBox"
                                  MinWidth="160"
                                  SelectedIndex="0"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.SelectSubject}"
                                         Description="{x:Static pageLangs:Resources.Settings_SelectSubjectDesc}"
                                         IconSource="{controls:FluentIconSource &#xE7C3;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox x:Name="SubjectComboBox"
                                  MinWidth="160"
                                  SelectedIndex="0"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.ShowWeight}"
                                         Description="{x:Static pageLangs:Resources.Settings_ShowWeightDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8EC;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch x:Name="ShowWeightSwitch"
                                      IsChecked="True"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>

            <!-- 表格区域 -->
            <Border x:Name="TableBorder"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="0"
                    Margin="0 12 0 0">
                <StackPanel>
                    <!-- 表头 -->
                    <StackPanel Orientation="Horizontal" Margin="8 8 8 4" x:Name="TableHeader">
                        <TextBlock Text="{x:Static pageLangs:Resources.SerialNumber}"
                                   Width="80" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="{x:Static pageLangs:Resources.PrizeName}"
                                   Width="150" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="{x:Static pageLangs:Resources.WinningTimes}"
                                   Width="100" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="{x:Static pageLangs:Resources.Weight}"
                                   Width="100" FontWeight="SemiBold" TextAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- 表格内容 -->
                    <ItemsControl x:Name="HistoryDataList" Margin="8 4 8 8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0 2">
                                    <TextBlock Width="80" TextAlignment="Center"/>
                                    <TextBlock Width="150" TextAlignment="Center"/>
                                    <TextBlock Width="100" TextAlignment="Center"/>
                                    <TextBlock Width="100" TextAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
