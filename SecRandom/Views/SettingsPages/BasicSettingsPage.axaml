<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="using:FluentAvalonia.UI.Controls"
             xmlns:controls="clr-namespace:SecRandom.Core.Controls;assembly=SecRandom.Core"
             xmlns:langs="using:SecRandom.Langs.Common"
             xmlns:pageLangs="using:SecRandom.Langs.SettingsPages.BasicSettingsPage"
             xmlns:media="using:Avalonia.Media"
             xmlns:configModels="using:SecRandom.Models.Config"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SecRandom.Views.SettingsPages.BasicSettingsPage"
             x:DataType="configModels:BasicSettingsConfig">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Margin="12 12 18 12" Spacing="12">
            <TextBlock Text="{x:Static pageLangs:Resources.BasicFeatures}"
                       FontSize="14"
                       FontWeight="SemiBold"/>
            
            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_AutoStart}"
                                         Description="{x:Static pageLangs:Resources.Settings_AutoStartDesc}"
                                         IconSource="{controls:FluentIconSource &#xE945;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding IsAutoStartEnabled}"
                                      OnContent=""
                                      OffContent=""/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ShowMainWindowOnStartup}"
                                         Description="{x:Static pageLangs:Resources.Settings_ShowMainWindowOnStartupDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8A7;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding IsShowMainWindowOnStartupEnabled}"
                                      OnContent=""
                                      OffContent=""/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_AutoSaveWindowSize}"
                                         Description="{x:Static pageLangs:Resources.Settings_AutoSaveWindowSizeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE74D;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding IsAutoSaveWindowSizeEnabled}"
                                      OnContent=""
                                      OffContent=""/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_MainWindowTopmost}"
                                         Description="{x:Static pageLangs:Resources.Settings_MainWindowTopmostDesc}"
                                         IconSource="{controls:FluentIconSource &#xE840;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding MainWindowTopmostMode}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.MainWindowTopmostOff}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.MainWindowTopmostWindow}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.MainWindowTopmostUia}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_BackgroundResident}"
                                         Description="{x:Static pageLangs:Resources.Settings_BackgroundResidentDesc}"
                                         IconSource="{controls:FluentIconSource &#xECCE;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding IsBackgroundResidentEnabled}"
                                      OnContent=""
                                      OffContent=""/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_RegisterUrlProtocolAndIpc}"
                                         Description="{x:Static pageLangs:Resources.Settings_RegisterUrlProtocolAndIpcDesc}"
                                         IconSource="{controls:FluentIconSource &#xE71B;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding IsUrlProtocolAndIpcEnabled}"
                                      OnContent=""
                                      OffContent=""/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>
            
            <TextBlock Text="{x:Static pageLangs:Resources.Personalised}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0 8 0 0"/>
            
            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_Theme}"
                                         Description="{x:Static pageLangs:Resources.Settings_ThemeDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding UiThemeModeIndex}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.ThemeFollowSystem}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.ThemeLight}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.ThemeDark}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_OpenThemeManagement}"
                                         Description="{x:Static pageLangs:Resources.Settings_OpenThemeManagementDesc}"
                                         IconSource="{controls:FluentIconSource &#xE790;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.Open}"
                                MinWidth="140"
                                Click="OpenThemeManagement_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>

                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_Language}"
                                         Description="{x:Static pageLangs:Resources.Settings_LanguageDesc}"
                                         IconSource="{controls:FluentIconSource &#xE774;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding UiLanguageMode}"
                                  MinWidth="140">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.LanguageFollowSystem}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.LanguageEnglish}" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.LanguageChineseSimplified}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_Font}"
                                         Description="{x:Static pageLangs:Resources.Settings_FontDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8D2;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox Name="FontFamilyComboBox"
                                  MinWidth="140"
                                  MaxDropDownHeight="320"
                                  AutoScrollToSelectedItem="True"
                                  IsTextSearchEnabled="True"
                                  SelectionChanged="FontFamilyComboBox_OnSelectionChanged">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="media:FontFamily">
                                    <TextBlock Text="{Binding Name}" FontFamily="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_FontWeight}"
                                         Description="{x:Static pageLangs:Resources.Settings_FontWeightDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8D2;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox Name="FontWeightComboBox"
                                  SelectedIndex="{Binding UiFontWeightIndex}"
                                  MinWidth="140"
                                  SelectionChanged="FontWeightComboBox_OnSelectionChanged">
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightThin}" FontWeight="Thin" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightExtraLight}" FontWeight="ExtraLight" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightLight}" FontWeight="Light" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightNormal}" FontWeight="Normal" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightMedium}" FontWeight="Medium" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightSemiBold}" FontWeight="SemiBold" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightBold}" FontWeight="Bold" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightExtraBold}" FontWeight="ExtraBold" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightBlack}" FontWeight="Black" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.FontWeightExtraBlack}" FontWeight="UltraBlack" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_DpiScale}"
                                         Description="{x:Static pageLangs:Resources.Settings_DpiScaleDesc}"
                                         IconSource="{controls:FluentIconSource &#xE7B5;}">
                    <fa:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding UiDpiScaleIndex}"
                                  MinWidth="140">
                            <ComboBoxItem Content="100%" />
                            <ComboBoxItem Content="125%" />
                            <ComboBoxItem Content="150%" />
                            <ComboBoxItem Content="175%" />
                            <ComboBoxItem Content="200%" />
                            <ComboBoxItem Content="{x:Static pageLangs:Resources.DpiScaleAuto}" />
                        </ComboBox>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>
            
            <TextBlock Text="{x:Static pageLangs:Resources.DataManagement}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0 8 0 0"/>
            
            <StackPanel Orientation="Vertical" Spacing="0">
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_LogViewer}"
                                         Description="{x:Static pageLangs:Resources.Settings_LogViewerDesc}"
                                         IconSource="{controls:FluentIconSource &#xE9F9;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.LogViewerButton}"
                                MinWidth="140"
                                Click="OpenLogViewer_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_BackupManager}"
                                         Description="{x:Static pageLangs:Resources.Settings_BackupManagerDesc}"
                                         IconSource="{controls:FluentIconSource &#xE74D;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.BackupManagerButton}"
                                MinWidth="140"
                                Click="OpenBackupManager_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ExportDiagnosticData}"
                                         Description="{x:Static pageLangs:Resources.Settings_ExportDiagnosticDataDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8A5;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.ExportDiagnosticDataButton}"
                                MinWidth="140"
                                Click="ExportDiagnosticData_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ExportSettings}"
                                         Description="{x:Static pageLangs:Resources.Settings_ExportSettingsDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8A5;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.ExportSettingsButton}"
                                MinWidth="140"
                                Click="ExportSettings_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ImportSettings}"
                                         Description="{x:Static pageLangs:Resources.Settings_ImportSettingsDesc}"
                                         IconSource="{controls:FluentIconSource &#xE8A5;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.ImportSettingsButton}"
                                MinWidth="140"
                                Click="ImportSettings_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ExportAllData}"
                                         Description="{x:Static pageLangs:Resources.Settings_ExportAllDataDesc}"
                                         IconSource="{controls:FluentIconSource &#xE7C3;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.ExportAllDataButton}"
                                MinWidth="140"
                                Click="ExportAllData_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
                
                <fa:SettingsExpanderItem Content="{x:Static pageLangs:Resources.Settings_ImportAllData}"
                                         Description="{x:Static pageLangs:Resources.Settings_ImportAllDataDesc}"
                                         IconSource="{controls:FluentIconSource &#xE7C3;}">
                    <fa:SettingsExpanderItem.Footer>
                        <Button Content="{x:Static pageLangs:Resources.ImportAllDataButton}"
                                MinWidth="140"
                                Click="ImportAllData_OnClick"/>
                    </fa:SettingsExpanderItem.Footer>
                </fa:SettingsExpanderItem>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
