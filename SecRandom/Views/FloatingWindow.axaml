<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="using:FluentAvalonia.UI.Controls"
        xmlns:controls="clr-namespace:SecRandom.Core.Controls;assembly=SecRandom.Core"
        xmlns:langs="clr-namespace:SecRandom.Langs.Common"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SecRandom.Views.FloatingWindow"
        Title="SecRandom"
        ShowActivated="False"
        Background="Transparent"
        Loaded="Control_OnLoaded">
    <Grid>
        <Border Background="{StaticResource SmokeFillColorDefaultBrush}"
                CornerRadius="24" ClipToBounds="True" />
        
        <StackPanel x:Name="RootStackPanel" VerticalAlignment="Center" HorizontalAlignment="Center" >
            <fa:CommandBarButton IconSource="{controls:FluentIconSource &#xECAB;}"
                                 Label="{x:Static langs:Resources.RollCall}"
                                 Click="OpenMainWindowButton_OnClick" />
        </StackPanel>
    </Grid>
</Window>
