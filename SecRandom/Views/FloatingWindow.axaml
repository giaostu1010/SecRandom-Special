<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:SecRandom.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SecRandom.Views.FloatingWindow"
        x:DataType="views:FloatingWindow"
        d:DataContext="{d:DesignInstance views:FloatingWindow}"
        Title="SecRandom"
        Width="1" Height="1"
        ShowActivated="False"
        Topmost="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="Transparent"
        CanMinimize="False"
        CanMaximize="False"
        CanResize="False"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Loaded="OnLoaded">
    <Grid>
        <Border Background="{StaticResource SolidBackgroundFillColorQuarternaryBrush}"
                Opacity="{Binding ViewModel.Config.FloatingWindowSettings.FloatingWindowOpacity}"
                CornerRadius="8" ClipToBounds="True" />
        
        <StackPanel x:Name="RootStackPanel"
                    Orientation="Vertical"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="4" />
    </Grid>
</Window>
