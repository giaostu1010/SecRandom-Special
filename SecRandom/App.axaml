<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SecRandom.App"
             RequestedThemeVariant="Default">
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/AppLogo.ico" ToolTipText="SecRandom" Menu="{DynamicResource AppMenu}" />
        </TrayIcons>
    </TrayIcon.Icons>
    
    <Application.Styles>
        <StyleInclude Source="/Styles.axaml"/>
        <Style Selector=":is(Window)">
            <Setter Property="Icon" Value="/Assets/AppLogo.png"/>
        </Style>
    </Application.Styles>
    
    <Application.Resources>
        <FontFamily x:Key="FluentSystemIconsResizeable">avares://SecRandom/Assets/Fonts/#FluentSystemIcons-Resizable</FontFamily>
        <FontFamily x:Key="AppFontFamily">HarmonyOS Sans SC</FontFamily>
        <FontWeight x:Key="AppFontWeight">Normal</FontWeight>
        
        <NativeMenu x:Key="AppMenu" />
    </Application.Resources>
</Application>
